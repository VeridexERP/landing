---
import "@/styles/global.css"

interface Props {
  title?: string
  description?: string
}

const {
  title = "Veridex ERP — Организација, транспорт и финансии без хаос",
  description = "Veridex ERP — Организација, транспорт и финансии без хаос. Направено во Македонија, за македонски бизниси.",
} = Astro.props
---

<html lang="mk">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
