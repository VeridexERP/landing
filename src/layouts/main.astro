---
import "@/styles/global.css"

interface Props {
  title?: string
  description?: string
  ogImage?: string
}

const {
  title = "Veridex ERP — Организација, транспорт и финансии без хаос",
  description = "Veridex ERP — Организација, транспорт и финансии без хаос. Направено во Македонија, за македонски бизниси.",
  ogImage = "/images/og.png",
} = Astro.props

const siteUrl = "https://veridexerp.com"
const ogImageUrl = `${siteUrl}${ogImage}`
---

<html lang="mk">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:site_name" content="Veridex ERP" />
    <meta property="og:locale" content="mk_MK" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
  </head>
  <body>
    <slot />
  </body>
</html>
