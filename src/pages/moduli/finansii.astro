---
import Layout from "@/layouts/main.astro"
import SiteHeader from "@/components/site-header"
import SiteFooter from "@/components/site-footer.astro"
---

<Layout
  title="Модул: Финансии — Veridex ERP"
  description="Влезни и излезни фактури, трошоци и финансиски извештаи. Секој денар следен, секој статус видлив."
>
  <SiteHeader client:load currentPath="/moduli/finansii" />

  <main class="pt-24">
    <section class="relative overflow-hidden py-16 md:py-24">
      <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-[oklch(0.48_0.22_275_/_0.05)]"></div>
      <div class="relative mx-auto max-w-7xl px-6">
        <div class="max-w-3xl">
          <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-primary/10 px-4 py-1.5 text-sm font-semibold text-primary">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-primary text-xs font-bold text-white">3</span>
            Модул
          </div>
          <h1 class="text-4xl font-extrabold tracking-tight md:text-5xl lg:text-6xl">
            Финансии
            <span class="text-gradient"> без изненадувања</span>
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-relaxed text-muted-foreground">
            Секоја фактура, секој трошок &mdash; со јасен статус и целосна
            историја. Поврзани со компании, возила, вработени и тури.
          </p>
          <a href="/kontakt" class="mt-8 inline-block">
            <button class="rounded-2xl bg-gradient-to-r from-primary to-[oklch(0.48_0.22_275)] px-8 py-3.5 text-sm font-semibold text-white shadow-lg shadow-primary/25 transition-all duration-300 hover:scale-105">
              Закажи демо
            </button>
          </a>
        </div>
      </div>
    </section>

    <section class="py-20 md:py-28">
      <div class="mx-auto max-w-7xl px-6">
        <div class="mb-16">
          <h2 class="text-3xl font-extrabold tracking-tight md:text-4xl">Што вклучува</h2>
          <p class="mt-4 max-w-2xl text-lg text-muted-foreground">
            Три столба за целосна финансиска контрола &mdash; секој поврзан
            со остатокот од системот.
          </p>
        </div>

        <div class="grid gap-8 md:grid-cols-3">
          <!-- Трошоци -->
          <div class="rounded-2xl border border-border/50 bg-white p-8">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" />
              </svg>
            </div>
            <h3 class="mb-3 text-xl font-bold">Трошоци</h3>
            <p class="mb-4 leading-relaxed text-muted-foreground">
              Универзални трошоци поврзани со компании, вработени, возила,
              приколки или тури. Категоризирани по тип и подтип.
            </p>
            <ul class="space-y-2 text-sm text-muted-foreground">
              <li class="flex items-center gap-2"><div class="h-1.5 w-1.5 rounded-full bg-primary"></div>Категоризација по тип и подтип</li>
              <li class="flex items-center gap-2"><div class="h-1.5 w-1.5 rounded-full bg-primary"></div>Поврзаност со било кој ентитет</li>
              <li class="flex items-center gap-2"><div class="h-1.5 w-1.5 rounded-full bg-primary"></div>Материјали и количини</li>
            </ul>
          </div>

          <!-- Влезни фактури -->
          <div class="rounded-2xl border border-border/50 bg-white p-8">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 3.75H6.912a2.25 2.25 0 0 0-2.15 1.588L2.35 13.177a2.25 2.25 0 0 0-.1.661V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18v-4.162c0-.224-.034-.447-.1-.661L19.24 5.338a2.25 2.25 0 0 0-2.15-1.588H15M2.25 13.5h3.86a2.25 2.25 0 0 1 2.012 1.244l.256.512a2.25 2.25 0 0 0 2.013 1.244h3.218a2.25 2.25 0 0 0 2.013-1.244l.256-.512a2.25 2.25 0 0 1 2.013-1.244h3.859M12 3v8.25m0 0-3-3m3 3 3-3" />
              </svg>
            </div>
            <h3 class="mb-3 text-xl font-bold">Влезни фактури</h3>
            <p class="mb-4 leading-relaxed text-muted-foreground">
              Фактури од добавувачи поврзани со компании, возила, вработени
              или тури. Со детални ставки и автоматски статуси.
            </p>
            <ul class="space-y-2 text-sm text-muted-foreground">
              <li class="flex items-center gap-2"><div class="h-1.5 w-1.5 rounded-full bg-primary"></div>Автоматски статуси и рокови</li>
              <li class="flex items-center gap-2"><div class="h-1.5 w-1.5 rounded-full bg-primary"></div>Детални ставки по фактура</li>
              <li class="flex items-center gap-2"><div class="h-1.5 w-1.5 rounded-full bg-primary"></div>Поврзаност со одржување на возила</li>
            </ul>
          </div>

          <!-- Излезни фактури -->
          <div class="rounded-2xl border border-border/50 bg-white p-8">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
              </svg>
            </div>
            <h3 class="mb-3 text-xl font-bold">Излезни фактури</h3>
            <p class="mb-4 leading-relaxed text-muted-foreground">
              Фактури кон клиенти поврзани со налози за тури.
              Креирање, следење на наплата и преглед на доцнења.
            </p>
            <ul class="space-y-2 text-sm text-muted-foreground">
              <li class="flex items-center gap-2"><div class="h-1.5 w-1.5 rounded-full bg-primary"></div>Поврзаност со налози за тури</li>
              <li class="flex items-center gap-2"><div class="h-1.5 w-1.5 rounded-full bg-primary"></div>Детални ставки</li>
              <li class="flex items-center gap-2"><div class="h-1.5 w-1.5 rounded-full bg-primary"></div>Следење на наплата и доцнења</li>
            </ul>
          </div>
        </div>

        <!-- Polymorphic explanation -->
        <div class="mt-16 rounded-2xl border border-border/50 bg-muted/30 p-8 md:p-10">
          <h3 class="mb-4 text-xl font-bold">Сè е поврзано</h3>
          <p class="mb-6 text-muted-foreground">
            Трошоците и влезните фактури не се изолирани записи &mdash; секој
            е поврзан со конкретен ентитет од системот. Тоа значи дека можете
            да видите:
          </p>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
            {["Колку чини секое возило", "Трошоци по вработен", "Расходи по компанија", "Трошоци по приколка", "Финансии по тура"].map((item) => (
              <div class="flex items-center gap-2 rounded-xl bg-white px-4 py-3">
                <div class="h-2 w-2 shrink-0 rounded-full bg-primary"></div>
                <span class="text-sm font-medium">{item}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="bg-muted/30 py-20 md:py-28">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <h2 class="text-3xl font-extrabold tracking-tight md:text-4xl">
          Подготвени за финансии
          <span class="text-gradient"> без изненадувања?</span>
        </h2>
        <p class="mx-auto mt-6 max-w-xl text-lg text-muted-foreground">
          Видете го модулот во акција со бесплатна демонстрација.
        </p>
        <a href="/kontakt" class="mt-8 inline-block">
          <button class="group relative overflow-hidden rounded-2xl bg-gradient-to-r from-primary to-[oklch(0.48_0.22_275)] px-10 py-4 text-lg font-semibold text-white shadow-2xl shadow-primary/30 transition-all duration-300 hover:scale-105">
            <span class="relative z-10">Закажи бесплатно демо</span>
            <div class="animate-shimmer absolute inset-0 -z-0 bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>
          </button>
        </a>
      </div>
    </section>
  </main>

  <SiteFooter />
</Layout>
