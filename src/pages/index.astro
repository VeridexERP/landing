---
import Layout from "@/layouts/main.astro"
import { Badge } from "@/components/ui/badge"
import SiteHeader from "@/components/site-header"
import SiteFooter from "@/components/site-footer.astro"
---

<Layout>
  <SiteHeader client:load />

  <main>
    <!-- Hero -->
    <section class="mesh-gradient grid-pattern relative min-h-screen overflow-hidden pt-24">
      <!-- Floating orbs -->
      <div
        class="animate-float pointer-events-none absolute top-32 left-[10%] h-72 w-72 rounded-full bg-primary/10 blur-3xl"
      ></div>
      <div
        class="animate-float-slow pointer-events-none absolute right-[15%] bottom-32 h-96 w-96 rounded-full bg-[oklch(0.48_0.22_275_/_0.08)] blur-3xl"
      ></div>
      <div
        class="animate-pulse-glow pointer-events-none absolute top-1/2 left-1/2 h-64 w-64 -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary/5 blur-3xl"
      ></div>

      <!-- Spinning ring decoration -->
      <div
        class="animate-spin-slow pointer-events-none absolute top-20 right-[5%] hidden h-96 w-96 opacity-[0.03] lg:block"
      >
        <div class="h-full w-full rounded-full border-2 border-dashed border-primary"></div>
      </div>

      <div class="relative mx-auto flex max-w-7xl flex-col items-center justify-center px-6 py-32 text-center md:py-40">
        <div class="animate-fade-in-up">
          <Badge
            variant="secondary"
            className="mb-8 border border-primary/20 bg-primary/5 px-5 py-2 text-sm font-medium text-primary"
          >
            <span class="mr-2 inline-block h-2 w-2 animate-pulse rounded-full bg-primary"></span>
            Направено во Македонија, за Македонија
          </Badge>
        </div>

        <h1
          class="animate-fade-in-up delay-100 max-w-5xl text-5xl leading-[1.1] font-extrabold tracking-tight md:text-7xl lg:text-8xl"
        >
          Организација, транспорт и финансии —
          <span class="text-gradient"> без хаос</span>
        </h1>

        <p
          class="animate-fade-in-up delay-200 mx-auto mt-8 max-w-2xl text-lg leading-relaxed text-muted-foreground md:text-xl"
        >
          Доста со расфрлани табели, изгубени фактури и рачно следење. Veridex ги
          обединува сите процеси на едно место — на македонски.
        </p>

        <div
          class="animate-fade-in-up delay-300 mt-12 flex flex-col items-center gap-4 sm:flex-row sm:gap-6"
        >
          <a href="#contact">
            <button
              class="group relative overflow-hidden rounded-2xl bg-gradient-to-r from-primary to-[oklch(0.48_0.22_275)] px-10 py-4 text-lg font-semibold text-white shadow-2xl shadow-primary/30 transition-all duration-300 hover:scale-105 hover:shadow-2xl hover:shadow-primary/40"
            >
              <span class="relative z-10">Закажи демо</span>
              <div
                class="animate-shimmer absolute inset-0 -z-0 bg-gradient-to-r from-transparent via-white/20 to-transparent"
              ></div>
            </button>
          </a>
          <a href="#modules">
            <button
              class="rounded-2xl border-2 border-primary/20 bg-white/50 px-10 py-4 text-lg font-semibold text-foreground backdrop-blur-sm transition-all duration-300 hover:scale-105 hover:border-primary/40 hover:bg-white/80"
            >
              Погледни ги модулите
            </button>
          </a>
        </div>

      </div>

      <!-- Bottom fade -->
      <div
        class="pointer-events-none absolute bottom-0 left-0 h-32 w-full bg-gradient-to-t from-background to-transparent"
      ></div>
    </section>

    <!-- Modules -->
    <section id="modules" class="relative overflow-hidden bg-muted/30 py-28 md:py-36">
      <div class="grid-pattern pointer-events-none absolute inset-0 opacity-50"></div>
      <div class="relative mx-auto max-w-7xl px-6">
        <div class="mb-20 text-center" data-animate="fade-up">
          <p class="mb-4 text-sm font-semibold tracking-widest text-primary uppercase">
            Детали
          </p>
          <h2 class="text-4xl font-extrabold tracking-tight md:text-5xl">
            Детален преглед на модулите
          </h2>
          <p class="mx-auto mt-6 max-w-2xl text-lg text-muted-foreground">
            Секој модул решава конкретни проблеми — без функции што никогаш
            нема да ги користите.
          </p>
        </div>

        <!-- Module 1: Организација -->
        <div class="mb-32 grid items-center gap-16 md:grid-cols-2">
          <div data-animate="slide-left">
            <div
              class="inline-flex items-center gap-2 rounded-full bg-primary/10 px-4 py-1.5 text-sm font-semibold text-primary"
            >
              <span class="flex h-6 w-6 items-center justify-center rounded-full bg-primary text-xs font-bold text-white">1</span>
              Модул
            </div>
            <h3 class="mt-6 text-3xl font-extrabold md:text-4xl">
              Целата организација на дланка
            </h3>
            <p class="mt-4 text-lg leading-relaxed text-muted-foreground">
              Повеќе не треба да прашувате „кој го има тој документ?" или „на
              која сметка е тоа?"
            </p>
            <ul class="mt-8 space-y-4">
              {[
                { title: "Компании", desc: "повеќе правни субјекти со банкарски сметки" },
                { title: "Вработени", desc: "договори, плати и возачки казни" },
                { title: "Возила и приколки", desc: "регистрација, документи и рокови" },
                { title: "Одржување", desc: "сервисна историја со автоматски потсетници" },
              ].map((item) => (
                <li class="flex items-start gap-4">
                  <div class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary/10">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-3.5 w-3.5 text-primary"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="3"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                    </svg>
                  </div>
                  <span class="text-base">
                    <strong class="font-semibold">{item.title}</strong>
                    <span class="text-muted-foreground"> — {item.desc}</span>
                  </span>
                </li>
              ))}
            </ul>
          </div>
          <div data-animate="slide-right">
            <div
              class="group relative overflow-hidden rounded-3xl bg-gradient-to-br from-primary/5 via-primary/10 to-[oklch(0.48_0.22_275_/_0.05)] p-1"
            >
              <div class="rounded-[calc(1.5rem-4px)] bg-white/80 p-12 backdrop-blur-sm">
                <div class="grid grid-cols-2 gap-6">
                  <div class="space-y-4 rounded-2xl bg-muted/50 p-5 transition-transform duration-300 hover:scale-105">
                    <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21" />
                      </svg>
                    </div>
                    <p class="text-sm font-semibold">Компании</p>
                    <div class="h-2 w-3/4 rounded-full bg-primary/20"></div>
                    <div class="h-2 w-1/2 rounded-full bg-primary/10"></div>
                  </div>
                  <div class="space-y-4 rounded-2xl bg-muted/50 p-5 transition-transform duration-300 hover:scale-105">
                    <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
                      </svg>
                    </div>
                    <p class="text-sm font-semibold">Вработени</p>
                    <div class="h-2 w-full rounded-full bg-primary/20"></div>
                    <div class="h-2 w-2/3 rounded-full bg-primary/10"></div>
                  </div>
                  <div class="space-y-4 rounded-2xl bg-muted/50 p-5 transition-transform duration-300 hover:scale-105">
                    <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Z" />
                      </svg>
                    </div>
                    <p class="text-sm font-semibold">Сметки</p>
                    <div class="h-2 w-2/3 rounded-full bg-primary/20"></div>
                    <div class="h-2 w-1/3 rounded-full bg-primary/10"></div>
                  </div>
                  <div class="space-y-4 rounded-2xl bg-muted/50 p-5 transition-transform duration-300 hover:scale-105">
                    <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                      </svg>
                    </div>
                    <p class="text-sm font-semibold">Документи</p>
                    <div class="h-2 w-5/6 rounded-full bg-primary/20"></div>
                    <div class="h-2 w-1/2 rounded-full bg-primary/10"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Module 2: Транспорт -->
        <div class="mb-32 grid items-center gap-16 md:grid-cols-2">
          <div class="order-2 md:order-1" data-animate="slide-left">
            <div
              class="group relative overflow-hidden rounded-3xl bg-gradient-to-br from-[oklch(0.48_0.22_275_/_0.05)] via-primary/10 to-primary/5 p-1"
            >
              <div class="rounded-[calc(1.5rem-4px)] bg-white/80 p-12 backdrop-blur-sm">
                <!-- Stylized route visualization -->
                <div class="relative">
                  <div class="flex items-center justify-between">
                    <div class="flex flex-col items-center gap-2">
                      <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-primary/10">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                        </svg>
                      </div>
                      <span class="text-xs font-medium text-muted-foreground">Почеток</span>
                    </div>
                    <div class="mx-4 h-0.5 flex-1 bg-gradient-to-r from-primary/40 via-primary/20 to-primary/40"></div>
                    <div class="flex flex-col items-center gap-2">
                      <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-primary text-white shadow-lg shadow-primary/30">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
                        </svg>
                      </div>
                      <span class="text-xs font-medium text-primary">Во тек</span>
                    </div>
                    <div class="mx-4 h-0.5 flex-1 bg-gradient-to-r from-primary/40 via-primary/20 to-muted"></div>
                    <div class="flex flex-col items-center gap-2">
                      <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-muted">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                        </svg>
                      </div>
                      <span class="text-xs font-medium text-muted-foreground">Крај</span>
                    </div>
                  </div>
                  <div class="mt-8 space-y-3">
                    <div class="flex items-center gap-3 rounded-xl bg-muted/50 p-3">
                      <div class="h-3 w-3 rounded-full bg-green-500"></div>
                      <span class="text-sm font-medium">SK-1234-AB</span>
                      <span class="ml-auto text-xs text-muted-foreground">Скопје → Битола</span>
                    </div>
                    <div class="flex items-center gap-3 rounded-xl bg-muted/50 p-3">
                      <div class="h-3 w-3 rounded-full bg-amber-500"></div>
                      <span class="text-sm font-medium">SK-5678-CD</span>
                      <span class="ml-auto text-xs text-muted-foreground">Сервис</span>
                    </div>
                    <div class="flex items-center gap-3 rounded-xl bg-muted/50 p-3">
                      <div class="h-3 w-3 rounded-full bg-primary"></div>
                      <span class="text-sm font-medium">SK-9012-EF</span>
                      <span class="ml-auto text-xs text-muted-foreground">Охрид → Струга</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="order-1 md:order-2" data-animate="slide-right">
            <div
              class="inline-flex items-center gap-2 rounded-full bg-primary/10 px-4 py-1.5 text-sm font-semibold text-primary"
            >
              <span class="flex h-6 w-6 items-center justify-center rounded-full bg-primary text-xs font-bold text-white">2</span>
              Модул
            </div>
            <h3 class="mt-6 text-3xl font-extrabold md:text-4xl">
              Транспортот под контрола
            </h3>
            <p class="mt-4 text-lg leading-relaxed text-muted-foreground">
              Кој вози каде? Со кое возило? Колку нарачки? Поврзете ги сите
              делови во една тура.
            </p>
            <ul class="mt-8 space-y-4">
              {[
                { title: "Тури", desc: "возило + приколка + возач + втор возач на едно место" },
                { title: "Налози", desc: "нарачки по тура со поврзани трошоци и фактури" },
                { title: "Трошоци по тура", desc: "секој расход евидентиран и поврзан" },
                { title: "Документи", desc: "прилози и документација по тура и налог" },
              ].map((item) => (
                <li class="flex items-start gap-4">
                  <div class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary/10">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                    </svg>
                  </div>
                  <span class="text-base">
                    <strong class="font-semibold">{item.title}</strong>
                    <span class="text-muted-foreground"> — {item.desc}</span>
                  </span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Module 3: Финансии -->
        <div class="grid items-center gap-16 md:grid-cols-2">
          <div data-animate="slide-left">
            <div
              class="inline-flex items-center gap-2 rounded-full bg-primary/10 px-4 py-1.5 text-sm font-semibold text-primary"
            >
              <span class="flex h-6 w-6 items-center justify-center rounded-full bg-primary text-xs font-bold text-white">3</span>
              Модул
            </div>
            <h3 class="mt-6 text-3xl font-extrabold md:text-4xl">
              Финансии без изненадувања
            </h3>
            <p class="mt-4 text-lg leading-relaxed text-muted-foreground">
              Секоја фактура, секој трошок, секоја плата — со јасен статус и
              целосна историја.
            </p>
            <ul class="mt-8 space-y-4">
              {[
                { title: "Трошоци", desc: "универзални, поврзани со возила, тури и вработени" },
                { title: "Влезни фактури", desc: "со ставки, статуси и поврзаност со одржување" },
                { title: "Излезни фактури", desc: "поврзани со налози за тури, следење на наплата" },
              ].map((item) => (
                <li class="flex items-start gap-4">
                  <div class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary/10">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                    </svg>
                  </div>
                  <span class="text-base">
                    <strong class="font-semibold">{item.title}</strong>
                    <span class="text-muted-foreground"> — {item.desc}</span>
                  </span>
                </li>
              ))}
            </ul>
          </div>
          <div data-animate="slide-right">
            <div
              class="group relative overflow-hidden rounded-3xl bg-gradient-to-br from-primary/5 via-primary/10 to-[oklch(0.48_0.22_275_/_0.05)] p-1"
            >
              <div class="rounded-[calc(1.5rem-4px)] bg-white/80 p-12 backdrop-blur-sm">
                <!-- Stylized financial dashboard -->
                <div class="space-y-6">
                  <div class="flex items-center justify-between">
                    <span class="text-sm font-semibold">Финансиски преглед</span>
                    <span class="rounded-lg bg-green-100 px-2.5 py-1 text-xs font-medium text-green-700">+12.5%</span>
                  </div>
                  <div class="flex items-end gap-2">
                    {[40, 65, 45, 80, 55, 90, 70, 85, 60, 95, 75, 88].map((h) => (
                      <div class="flex-1 rounded-t-md bg-gradient-to-t from-primary/40 to-primary/20 transition-all duration-300 hover:from-primary/60 hover:to-primary/40" style={`height: ${h}px`}></div>
                    ))}
                  </div>
                  <div class="grid grid-cols-2 gap-4">
                    <div class="rounded-xl bg-muted/50 p-4">
                      <p class="text-xs text-muted-foreground">Влезни</p>
                      <p class="mt-1 text-lg font-bold text-primary">ден. 2.4M</p>
                    </div>
                    <div class="rounded-xl bg-muted/50 p-4">
                      <p class="text-xs text-muted-foreground">Излезни</p>
                      <p class="mt-1 text-lg font-bold">ден. 1.8M</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Veridex -->
    <section id="why" class="relative overflow-hidden py-28 md:py-36">
      <div class="mx-auto max-w-7xl px-6">
        <div class="mb-20 text-center" data-animate="fade-up">
          <p class="mb-4 text-sm font-semibold tracking-widest text-primary uppercase">
            Предности
          </p>
          <h2 class="text-4xl font-extrabold tracking-tight md:text-5xl">
            Зошто компании го избираат Veridex?
          </h2>
          <p class="mx-auto mt-6 max-w-2xl text-lg text-muted-foreground">
            Затоа што е направен за тоа како работите вие, а не за тоа како
            работат во Америка.
          </p>
        </div>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {[
            {
