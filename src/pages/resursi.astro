---
import Layout from "@/layouts/main.astro"
import SiteHeader from "@/components/site-header"
import SiteFooter from "@/components/site-footer.astro"

const resources = [
  {
    title: "Veridex ERP \u2014 Брошура",
    description:
      "Целосен преглед на сите модули, функционалности и предности на Veridex ERP. Идеално за споделување со тимот или менаџментот.",
    file: "/documents/veridex-brochure.pdf",
    category: "Преглед",
    icon: "book",
  },
  {
    title: "Veridex на една страница",
    description:
      "Сè што треба да знаете за Veridex на една страница. Брз преглед на модулите, цената и клучните предности.",
    file: "/documents/veridex-onepager.pdf",
    category: "Преглед",
    icon: "doc",
  },
  {
    title: "Veridex vs. Excel",
    description:
      "Детална споредба меѓу управување со бизнис процеси во Excel табели и во Veridex ERP. Кога е време за промена?",
    file: "/documents/veridex-vs-excel.pdf",
    category: "Споредба",
    icon: "compare",
  },
  {
    title: "План за имплементација",
    description:
      "Чекор по чекор \u2014 како изгледа процесот од првиот контакт до целосно оперативен систем. Временска рамка и фази.",
    file: "/documents/veridex-timeline.pdf",
    category: "Водич",
    icon: "timeline",
  },
]

const icons: Record<string, string> = {
  book: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />`,
  doc: `<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />`,
  compare: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />`,
  timeline: `<path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />`,
}
---

<Layout
  title="Ресурси — Veridex ERP"
  description="Преземете брошури, водичи и споредби за Veridex ERP. Бесплатни материјали за вашиот тим."
>
  <SiteHeader client:load currentPath="/resursi" />

  <main class="pt-24">
    <section class="py-16 md:py-24">
      <div class="mx-auto max-w-5xl px-6">
        <div class="mb-16">
          <a
            href="/"
            class="mb-6 inline-flex items-center gap-2 text-sm text-muted-foreground transition-colors duration-200 hover:text-primary"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
            </svg>
            Назад кон почетна
          </a>
          <h1 class="text-4xl font-extrabold tracking-tight md:text-5xl">Ресурси</h1>
          <p class="mt-4 max-w-2xl text-lg text-muted-foreground">
            Бесплатни материјали за преземање. Споделете ги со тимот или
            искористете ги за да ја донесете одлуката полесно.
          </p>
        </div>

        <div class="grid gap-6 sm:grid-cols-2">
          {resources.map((res) => (
            <div class="group relative overflow-hidden rounded-2xl border border-border/50 bg-white p-8 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-primary/5">
              <div class="absolute top-0 right-0 h-24 w-24 translate-x-6 -translate-y-6 rounded-full bg-primary/5 transition-transform duration-500 group-hover:scale-150"></div>
              <div class="relative">
                <div class="mb-2 flex items-center justify-between">
                  <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-6 w-6 text-primary"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="1.5"
                      set:html={icons[res.icon]}
                    />
                  </div>
                  <span class="rounded-lg bg-muted px-3 py-1 text-xs font-medium text-muted-foreground">
                    {res.category}
                  </span>
                </div>

                <h2 class="mt-5 text-xl font-bold">{res.title}</h2>
                <p class="mt-3 leading-relaxed text-muted-foreground">
                  {res.description}
                </p>

                <div class="mt-6 flex items-center gap-4">
                  <a
                    href={res.file}
                    download
                    class="inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-primary to-[oklch(0.48_0.22_275)] px-5 py-2.5 text-sm font-semibold text-white shadow-lg shadow-primary/20 transition-all duration-300 hover:scale-105 hover:shadow-xl hover:shadow-primary/25"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
                    </svg>
                    Преземи PDF
                  </a>
                  <a
                    href={res.file}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-sm font-medium text-muted-foreground transition-colors duration-200 hover:text-primary"
                  >
                    Отвори &rarr;
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- CTA -->
        <div class="mt-20 rounded-2xl bg-muted/50 p-10 text-center md:p-14">
          <h3 class="text-2xl font-bold md:text-3xl">
            Сакате да видите сè во живо?
          </h3>
          <p class="mx-auto mt-4 max-w-lg text-muted-foreground">
            Документите се добар почеток, но ништо не го заменува вистинското
            демо. Закажете бесплатна демонстрација.
          </p>
          <a href="/kontakt" class="mt-8 inline-block">
            <button
              class="group relative overflow-hidden rounded-2xl bg-gradient-to-r from-primary to-[oklch(0.48_0.22_275)] px-10 py-4 text-lg font-semibold text-white shadow-2xl shadow-primary/30 transition-all duration-300 hover:scale-105 hover:shadow-2xl hover:shadow-primary/40"
            >
              <span class="relative z-10">Закажи бесплатно демо</span>
              <div class="animate-shimmer absolute inset-0 -z-0 bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>
            </button>
          </a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</Layout>
