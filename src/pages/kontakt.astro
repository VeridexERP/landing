---
import Layout from "@/layouts/main.astro"
import SiteHeader from "@/components/site-header"
import SiteFooter from "@/components/site-footer.astro"
---

<Layout
  title="Контакт — Veridex ERP"
  description="Закажете бесплатна демонстрација на Veridex ERP или контактирајте нè за повеќе информации."
>
  <SiteHeader client:load currentPath="/kontakt" />

  <main class="pt-24">
    <section class="relative overflow-hidden py-16 md:py-24">
      <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-[oklch(0.48_0.22_275_/_0.05)]"></div>
      <div class="grid-pattern pointer-events-none absolute inset-0 opacity-30"></div>

      <div class="relative mx-auto max-w-7xl px-6">
        <div class="mb-16">
          <a
            href="/"
            class="mb-6 inline-flex items-center gap-2 text-sm text-muted-foreground transition-colors duration-200 hover:text-primary"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
            </svg>
            Назад кон почетна
          </a>
          <h1 class="text-4xl font-extrabold tracking-tight md:text-5xl">Контакт</h1>
          <p class="mt-4 max-w-2xl text-lg text-muted-foreground">
            Закажете бесплатна демонстрација или поставете прашање — одговараме
            во рок од 24 часа.
          </p>
        </div>

        <div class="grid items-start gap-16 md:grid-cols-2">
          <!-- Left: info -->
          <div>
            <div class="space-y-6">
              <div class="flex items-center gap-4">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-primary/10">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm text-muted-foreground">Е-пошта</p>
                  <a href="mailto:info@veridex.mk" class="text-lg font-medium transition-colors duration-200 hover:text-primary">info@veridex.mk</a>
                </div>
              </div>
              <div class="flex items-center gap-4">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-primary/10">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm text-muted-foreground">Одговараме во рок од</p>
                  <p class="text-lg font-medium">24 часа</p>
                </div>
              </div>
              <div class="flex items-center gap-4">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-primary/10">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm text-muted-foreground">Демото е</p>
                  <p class="text-lg font-medium">Бесплатно, без обврска</p>
                </div>
              </div>
            </div>

            <div class="mt-12 rounded-2xl border border-border/50 bg-white p-8">
              <h3 class="mb-4 text-lg font-bold">Што вклучува демото?</h3>
              <ul class="space-y-3">
                {[
                  "Преглед на сите три модули",
                  "Дискусија за вашите специфични потреби",
                  "Одговори на сите технички прашања",
                  "План за имплементација и миграција",
                ].map((item) => (
                  <li class="flex items-start gap-3">
                    <div class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary/10">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                      </svg>
                    </div>
                    <span class="text-sm text-muted-foreground">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <!-- Right: form -->
          <div>
            <div class="overflow-hidden rounded-3xl border border-border/50 bg-white p-8 shadow-xl shadow-primary/5 md:p-10">
              <h2 class="mb-6 text-xl font-bold">Пратете ни порака</h2>
              <form id="contact-form" class="space-y-5">
                <div class="grid gap-5 sm:grid-cols-2">
                  <div>
                    <label for="name" class="mb-1.5 block text-sm font-medium">Име и презиме</label>
                    <input
                      type="text"
                      id="name"
                      name="name"
                      required
                      class="w-full rounded-xl border border-border bg-background px-4 py-3 text-sm transition-colors duration-200 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20"
                      placeholder="Марко Маркоски"
                    />
                  </div>
                  <div>
                    <label for="company" class="mb-1.5 block text-sm font-medium">Компанија</label>
                    <input
                      type="text"
                      id="company"
                      name="company"
                      required
                      class="w-full rounded-xl border border-border bg-background px-4 py-3 text-sm transition-colors duration-200 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20"
                      placeholder="Назив на компанија"
                    />
                  </div>
                </div>
                <div class="grid gap-5 sm:grid-cols-2">
                  <div>
                    <label for="email" class="mb-1.5 block text-sm font-medium">Е-пошта</label>
                    <input
                      type="email"
                      id="email"
                      name="email"
                      required
                      class="w-full rounded-xl border border-border bg-background px-4 py-3 text-sm transition-colors duration-200 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20"
                      placeholder="marko@kompanija.mk"
                    />
                  </div>
                  <div>
                    <label for="phone" class="mb-1.5 block text-sm font-medium">
                      Телефон <span class="text-muted-foreground">(опционално)</span>
                    </label>
                    <input
                      type="tel"
                      id="phone"
                      name="phone"
                      class="w-full rounded-xl border border-border bg-background px-4 py-3 text-sm transition-colors duration-200 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20"
                      placeholder="+389 7X XXX XXX"
                    />
                  </div>
                </div>
                <div>
                  <label for="message" class="mb-1.5 block text-sm font-medium">
                    Порака <span class="text-muted-foreground">(опционално)</span>
                  </label>
                  <textarea
                    id="message"
                    name="message"
                    rows="5"
                    class="w-full resize-none rounded-xl border border-border bg-background px-4 py-3 text-sm transition-colors duration-200 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20"
                    placeholder="Кажете ни повеќе за вашиот бизнис или прашања..."
                  ></textarea>
                </div>
                <button
                  type="submit"
                  id="submit-btn"
                  class="group relative w-full overflow-hidden rounded-2xl bg-gradient-to-r from-primary to-[oklch(0.48_0.22_275)] px-10 py-4 text-lg font-semibold text-white shadow-xl shadow-primary/25 transition-all duration-300 hover:scale-[1.02] hover:shadow-2xl hover:shadow-primary/30 disabled:pointer-events-none disabled:opacity-60"
                >
                  <span id="btn-text" class="relative z-10">Испрати порака</span>
                  <span id="btn-loading" class="relative z-10 hidden items-center justify-center gap-2">
                    <svg class="h-5 w-5 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                    Се испраќа...
                  </span>
                  <div class="animate-shimmer absolute inset-0 -z-0 bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>
                </button>
              </form>

              <!-- Success state -->
              <div id="form-success" class="hidden py-12 text-center">
                <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-green-100">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                </div>
                <h3 class="text-2xl font-bold">Пораката е испратена!</h3>
                <p class="mt-3 text-muted-foreground">
                  Ќе ве контактираме во рок од 24 часа.
                </p>
              </div>

              <!-- Error state -->
              <div id="form-error" class="mt-4 hidden rounded-xl bg-red-50 p-4 text-sm text-red-700">
                Настана грешка при испраќање. Обидете се повторно или пишете ни на
                <a href="mailto:info@veridex.mk" class="font-medium underline">info@veridex.mk</a>.
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</Layout>

<script>
  // Contact form
  const form = document.getElementById("contact-form") as HTMLFormElement | null
  const btnText = document.getElementById("btn-text")
  const btnLoading = document.getElementById("btn-loading")
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement | null
  const formSuccess = document.getElementById("form-success")
  const formError = document.getElementById("form-error")

  if (form && btnText && btnLoading && submitBtn && formSuccess && formError) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault()
      formError.classList.add("hidden")
      submitBtn.disabled = true
      btnText.classList.add("hidden")
      btnLoading.classList.remove("hidden")
      btnLoading.classList.add("flex")

      const data = Object.fromEntries(new FormData(form))

      try {
        const endpoint = form.dataset.endpoint
        if (endpoint) {
          const res = await fetch(endpoint, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data),
          })
          if (!res.ok) throw new Error("Failed")
        } else {
          const subject = encodeURIComponent(`Контакт — ${data.company}`)
          const body = encodeURIComponent(
            `Име: ${data.name}\nКомпанија: ${data.company}\nЕ-пошта: ${data.email}\nТелефон: ${data.phone || "/"}\n\nПорака:\n${data.message || "/"}`
          )
          window.open(`mailto:info@veridex.mk?subject=${subject}&body=${body}`)
        }

        form.classList.add("hidden")
        formSuccess.classList.remove("hidden")
      } catch {
        formError.classList.remove("hidden")
        submitBtn.disabled = false
        btnText.classList.remove("hidden")
        btnLoading.classList.add("hidden")
        btnLoading.classList.remove("flex")
      }
    })
  }
</script>
