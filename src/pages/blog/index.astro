---
import Layout from "@/layouts/main.astro"
import SiteHeader from "@/components/site-header"
import SiteFooter from "@/components/site-footer.astro"
import { getCollection } from "astro:content"

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
)

function formatDate(date: Date) {
  return date.toLocaleDateString("mk-MK", {
    year: "numeric",
    month: "long",
    day: "numeric",
  })
}
---

<Layout
  title="Блог — Veridex ERP"
  description="Совети, водичи и увиди за дигитализација на бизнис процеси, управување со флота и финансии."
>
  <SiteHeader client:load currentPath="/blog" />

  <main class="pt-24">
    <section class="py-16 md:py-24">
      <div class="mx-auto max-w-4xl px-6">
        <div class="mb-16">
          <a
            href="/"
            class="mb-6 inline-flex items-center gap-2 text-sm text-muted-foreground transition-colors duration-200 hover:text-primary"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
            </svg>
            Назад кон почетна
          </a>
          <h1 class="text-4xl font-extrabold tracking-tight md:text-5xl">Блог</h1>
          <p class="mt-4 max-w-2xl text-lg text-muted-foreground">
            Совети и увиди за дигитализација на бизнис процеси — од табели до
            систем.
          </p>
        </div>

        <div class="space-y-8">
          {posts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="group block overflow-hidden rounded-2xl border border-border/50 bg-white transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-primary/5"
            >
              {post.data.image && (
                <div class="overflow-hidden border-b border-border/50 bg-muted/30">
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class="h-48 w-full object-cover object-top transition-transform duration-500 group-hover:scale-[1.03] md:h-56"
                  />
                </div>
              )}
              <div class="flex flex-col gap-4 p-8">
                <time datetime={post.data.date.toISOString()} class="text-sm text-muted-foreground">
                  {formatDate(post.data.date)}
                </time>
                <h2 class="text-2xl font-bold transition-colors duration-200 group-hover:text-primary">
                  {post.data.title}
                </h2>
                <p class="leading-relaxed text-muted-foreground">
                  {post.data.description}
                </p>
                <span class="inline-flex items-center gap-1 text-sm font-medium text-primary">
                  Прочитај повеќе
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                  </svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</Layout>
